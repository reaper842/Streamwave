{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist/server",
    "rootDir": ".",
    "baseUrl": ".",
    "noEmit": true
  },
  "include": ["server/**/*", "prisma/seed.ts", "src/generated/prisma/**/*"],
  "exclude": ["node_modules", "src/app", "src/components", "src/hooks", "src/stores", ".next"]
}
