// StreamWave — Prisma Schema
// After changes: npx prisma migrate dev --name <name> && npx prisma generate

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String?
  display_name  String
  avatar_url    String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  playlists                Playlist[]
  liked_songs              LikedSong[]
  followed_artists         FollowedArtist[]
  saved_albums             SavedAlbum[]
  notification_preferences NotificationPreferences?

  @@map("users")
}

// ─── Artist ──────────────────────────────────────────────────────────────────

model Artist {
  id         String   @id @default(uuid())
  name       String
  bio        String?
  image_url  String?
  genre      String?
  created_at DateTime @default(now())

  albums           Album[]
  tracks           Track[]
  followed_by      FollowedArtist[]

  @@index([name])
  @@map("artists")
}

// ─── Album ───────────────────────────────────────────────────────────────────

model Album {
  id           String   @id @default(uuid())
  title        String
  artist_id    String
  cover_url    String?
  release_date DateTime?
  genre        String?
  created_at   DateTime @default(now())

  artist       Artist  @relation(fields: [artist_id], references: [id], onDelete: Cascade)
  tracks       Track[]
  saved_by     SavedAlbum[]

  @@index([artist_id])
  @@index([title])
  @@map("albums")
}

// ─── Track ───────────────────────────────────────────────────────────────────

model Track {
  id           String   @id @default(uuid())
  title        String
  artist_id    String
  album_id     String
  duration_ms  Int
  audio_url    String
  track_number Int
  created_at   DateTime @default(now())

  artist         Artist          @relation(fields: [artist_id], references: [id], onDelete: Cascade)
  album          Album           @relation(fields: [album_id], references: [id], onDelete: Cascade)
  playlist_tracks PlaylistTrack[]
  liked_by       LikedSong[]

  @@index([artist_id])
  @@index([album_id])
  @@index([title])
  @@map("tracks")
}

// ─── Playlist ─────────────────────────────────────────────────────────────────

model Playlist {
  id          String   @id @default(uuid())
  user_id     String
  name        String
  description String?
  cover_url   String?
  is_public   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user   User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  @@index([user_id])
  @@index([name])
  @@map("playlists")
}

// ─── PlaylistTrack ────────────────────────────────────────────────────────────

model PlaylistTrack {
  playlist_id String
  track_id    String
  position    Int
  added_at    DateTime @default(now())

  playlist Playlist @relation(fields: [playlist_id], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [track_id], references: [id], onDelete: Cascade)

  @@id([playlist_id, track_id])
  @@index([playlist_id])
  @@index([track_id])
  @@map("playlist_tracks")
}

// ─── LikedSong ────────────────────────────────────────────────────────────────

model LikedSong {
  user_id  String
  track_id String
  liked_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  track Track @relation(fields: [track_id], references: [id], onDelete: Cascade)

  @@id([user_id, track_id])
  @@index([user_id])
  @@index([track_id])
  @@map("liked_songs")
}

// ─── FollowedArtist ───────────────────────────────────────────────────────────

model FollowedArtist {
  user_id     String
  artist_id   String
  followed_at DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artist_id], references: [id], onDelete: Cascade)

  @@id([user_id, artist_id])
  @@index([user_id])
  @@index([artist_id])
  @@map("followed_artists")
}

// ─── SavedAlbum ───────────────────────────────────────────────────────────────

model SavedAlbum {
  user_id  String
  album_id String
  saved_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  album Album @relation(fields: [album_id], references: [id], onDelete: Cascade)

  @@id([user_id, album_id])
  @@index([user_id])
  @@index([album_id])
  @@map("saved_albums")
}

// ─── NotificationPreferences ─────────────────────────────────────────────────

model NotificationPreferences {
  user_id          String  @id
  new_releases     Boolean @default(true)
  playlist_updates Boolean @default(false)
  account_security Boolean @default(true)
  product_updates  Boolean @default(false)
  updated_at       DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
