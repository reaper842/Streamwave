# ── StreamWave Production Environment Variables ───────────────────────────────
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to version control.
#
# Cloudflare Tunnel routes traffic to containers by their service name (hostname):
#   streamwave.yourdomain.com         → http://nextjs:3000
#   streamwave-api.yourdomain.com     → http://fastify:3001
# IMPORTANT: Use first-level subdomains only (e.g. "streamwave-api.yourdomain.com", NOT
# "api.streamwave.yourdomain.com"). Cloudflare Universal SSL (free plan) only covers
# first-level subdomains (*.yourdomain.com); second-level subdomains get ERR_SSL_VERSION_OR_CIPHER_MISMATCH.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL credentials (also used by docker-compose.prod.yml via ${VAR} substitution)
POSTGRES_USER=streamwave
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=streamwave

# Full connection string used by Prisma (references the postgres service name)
DATABASE_URL=postgresql://streamwave:CHANGE_ME_strong_db_password@postgres:5432/streamwave

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Meilisearch ──────────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://meilisearch:7700
# Generate with: openssl rand -hex 32
MEILISEARCH_API_KEY=CHANGE_ME_strong_meili_master_key

# ─── Cloudflare R2 (optional — skip if using local audio files) ───────────────
# If all audio_url fields in the DB start with "/" the server bypasses R2 entirely.
# Set these only if you upload files to R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=streamwave-audio
R2_PUBLIC_URL=

# ─── NextAuth.js ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_generated_secret
# Your public domain for the Next.js app (NO trailing slash)
NEXTAUTH_URL=https://streamwave.yourdomain.com
# Required when running behind a reverse proxy (Cloudflare Tunnel, nginx, etc.)
# Tells NextAuth to trust the X-Forwarded-Host header from the proxy
AUTH_TRUST_HOST=true
# Cookie domain — set to ".yourdomain.com" (leading dot) so the session cookie
# is sent to BOTH streamwave.yourdomain.com AND streamwave-api.yourdomain.com.
# Required when Next.js and Fastify are on different subdomains of the same domain.
COOKIE_DOMAIN=.yourdomain.com

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# Create at https://console.cloud.google.com/
# Authorized redirect URI: https://streamwave.yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth (optional) ──────────────────────────────────────────────────
# Create at https://github.com/settings/developers
# Authorization callback URL: https://streamwave.yourdomain.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── SMTP (optional — for password reset emails) ──────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@streamwave.yourdomain.com

# ─── App ──────────────────────────────────────────────────────────────────────
# Browser-side API URL — this is what the user's browser fetches from.
# Must be a publicly reachable URL (Cloudflare Tunnel hostname for Fastify).
NEXT_PUBLIC_API_URL=https://api.streamwave.yourdomain.com

# Internal URL: how Next.js server-side code (NextAuth Credentials provider) reaches Fastify.
# Inside Docker network use the service name.
FASTIFY_API_URL=http://fastify:3001

# ─── Cloudflare Tunnel ───────────────────────────────────────────────────────
# Get this from: Cloudflare Dashboard → Zero Trust → Networks → Tunnels
# → Create tunnel → Copy the token shown in the cloudflared install command
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_cloudflare_tunnel_token

# ─── Node.js ──────────────────────────────────────────────────────────────────
NODE_ENV=production
